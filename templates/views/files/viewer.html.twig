{% extends 'container_layout.html.twig' %}

{% block metatags %}
{% set metaDescription = "" %}
{% set metaTitle = file.name %}
<title>{{ metaTitle }}</title>
<meta name="description" content="{{ metaDescription }}"/>
<meta property="og:title" content="{{ metaTitle }}" />
<meta property="og:description" content="{{ metaDescription }}" />
{% endblock %}

{% block breadcrumb %}
{{ renderBreadcrumb(file) }}
{% endblock %}

{% block pageTitle %}
{{ file.name }}
{% endblock %}

{% block pageContent %}
{% set premiumUser = isPremium() %}
{% if premiumUser %}
<div
  class="file-ai-root"
  data-file-ai-chat
  data-file-ai-endpoint="{{ path('file_ai_chat', {fileId: file.id}) }}"
  data-file-ai-file-name="{{ file.name }}"
  data-file-ai-csrf-token="{{ csrf_token('file_ai_chat_' ~ file.id) }}"
>
{% endif %}
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
  <div class="col-span-12 lg:col-span-8">
    <div class="file-viewer-shell">
      <iframe
        src="/viewer/web/viewer.html?file={{ path('file_pdf', { fileId: file.id })|url_encode }}"
        width="100%"
        height="650px"
        class="file-viewer-frame"
        title="{{ file.name }}"
      >
      </iframe>
    </div>
  </div>
  <div class="col-span-12 lg:col-span-4">
    <div class="sticky">
      {% if premiumUser %}
      <div class="simple-box mb-4">
        <h4 class="h4 mb-4">Preguntar a la IA sobre este PDF</h4>
        <p class="mb-4">
          Abre un chat centrado solo en este documento para pedir resúmenes, explicaciones paso a paso o aclaraciones sobre cualquier apartado.
        </p>
        <button type="button" class="btn btn-secondary block w-full text-center" data-file-ai-open>
          Preguntar a la IA
        </button>
      </div>
      {% else %}
      <div class="simple-box mb-4">
        <h4 class="h4 mb-4">Desbloquea el tutor IA de este PDF</h4>
        <p class="mb-4">
          Hazte Premium para poder preguntar dudas sobre este documento y recibir respuestas centradas solo en su contenido.
        </p>
        <a class="btn btn-secondary block text-center"
          href="{{ path('app_register') }}"
          rel="nofollow"
          onclick="gtag('event', 'click', {
            'event_category': 'premium-box-ai',
            'event_label': 'file-viewer-sidebar'
          });"
        >
          Quiero hacerme premium
        </a>
      </div>
      {% endif %}

      {% if not premiumUser %}
      <div class="simple-box">
        <h4 class="h4 mb-4">¿Quieres acceder a más contenido aún?</h4>
        <p>Con Clases de Apoyo Premium podrás acceder a los exámenes de selectividad resueltos de todos los años, a las soluciones
        de los ejercicios que te proponemos en cada tema y todo ello sin ver un anuncio más.</p>
        <a class="btn btn-secondary block text-center"
          href="{{path('app_register')}}"
          rel="nofollow"
          onclick="gtag('event', 'click', {
            'event_category': 'premium-box',
            'event_label': 'file-viewer'
          });"
        >
          Quiero hacerme premium
        </a>
      </div>
      {% endif %}
    </div>
  </div>
  {% if premiumUser %}
  <div class="col-span-12">
    <div class="file-ai-root">
      <div class="file-ai-backdrop" data-file-ai-backdrop></div>

      <aside
        class="file-ai-drawer"
        data-file-ai-drawer
        aria-hidden="true"
        aria-label="Chat sobre este archivo"
      >
        <div class="file-ai-drawer-header">
          <div>
            <p class="file-ai-kicker">Tutor IA del documento</p>
            <h2 class="file-ai-title">Preguntar a la IA</h2>
          </div>

          <button type="button" class="file-ai-close-button" data-file-ai-close aria-label="Cerrar chat">
            Cerrar
          </button>
        </div>

        <div class="file-ai-message-list" data-file-ai-messages>
          <div class="file-ai-info-card">
            <p class="file-ai-info-title">{{ file.name }}</p>
            <p class="file-ai-info-text">
              La IA analizará este PDF completo y solo responderá dudas relacionadas con el archivo. Si la pregunta se sale del documento, la rechazará. Recuerda que la IA puede cometer errores, así que revisa todas las respuestas cuidadosamente.
            </p>
          </div>

          <div class="file-ai-empty-state" data-file-ai-empty>
            <p class="file-ai-empty-title">Haz tu primera pregunta</p>
            <p class="file-ai-empty-text">
              Ejemplo: Explícame este apartado paso a paso o resúmeme las ideas clave de este tema.
            </p>
          </div>
        </div>

        <div class="file-ai-error" data-file-ai-error hidden></div>

        <form class="file-ai-composer" data-file-ai-form>
          <label for="file-ai-input-{{ file.id }}" class="sr-only">Escribe una duda sobre este archivo</label>
          <textarea
            id="file-ai-input-{{ file.id }}"
            class="file-ai-textarea"
            data-file-ai-input
            rows="1"
            placeholder="Escribe una duda sobre este archivo"
          ></textarea>

          <button type="submit" class="file-ai-send-button" data-file-ai-submit>
            Enviar
          </button>
        </form>
      </aside>
    </div>
  </div>
  {% endif %}
</div>
{% if premiumUser %}
</div>
{% endif %}
{% endblock %}
