{% extends 'base.html.twig' %}

{% block title %}Iniciar sesión{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8 lg:h-[600px]">
  <div class="flex justify-center items-center h-full">
    <div class="simple-box">
      {% for flashSuccess in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ flashSuccess }}</div>
      {% endfor %}
      <form action="{{ path('app_login') }}" method="post">
        {% if error %}
        <div class="alert alert-danger">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
        {% endif %}
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />
        <div class="form-group">
          <label for="username" class="label">
            Email
          </label>
          <input 
            class="form-control" 
            type="text" 
            id="username" 
            name="_username" 
            value="{{ last_username }}" 
            required="required"
          />
        </div>

        <div class="form-group">
          <label for="password" class="label">
            Contraseña
          </label>
          <input 
            class="form-control"
            type="password" 
            id="password" 
            name="_password" 
            required="required"
          />
        </div>
        <input type="hidden" name="_target_path" value="/u/suscripcion/pago"/>

        <div class="form-group form-check">
          <input class="form-check-input"
                type="checkbox" 
                id="remember_me" 
                name="_remember_me" 
                value="on" />
          <label class="form-check-label" 
                for="remember_me">
                Recordar inicio de sesión
          </label>
        </div>

        <input 
          class="btn-primary w-full" 
          type="submit" 
          id="_submit" 
          name="_submit" 
          value="Iniciar sesión" 
        />
      </form>
      <div class="mt-8 pt-8 border-t border-t-solid border-t-gray-400">
        <p>
          <a class="text-primary" href="{{ path('app_forgot_password_request') }}">Recuperar contraseña</a>
        </p>
        <a class="btn btn-outline-primary btn-block" 
          href="{{ path('app_register')}}">
          Crear cuenta en Clases de Apoyo
        </a>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('build/login.css') }}">
{% endblock stylesheets %}