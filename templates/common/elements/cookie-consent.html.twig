{% if consent_available %}
<div
  id="cookie-consent-dialog"
  class="fixed inset-0 z-40 flex items-end sm:items-center justify-center px-4 py-6 bg-black/50 hidden"
  data-cookie-banner
  role="dialog"
  aria-hidden="true"
  aria-modal="true"
  aria-labelledby="cookie-consent-title"
  aria-describedby="cookie-consent-description"
>
  <div class="w-full max-w-3xl bg-white rounded-2xl shadow-2xl overflow-hidden">
    <div class="px-6 pt-6 pb-4 sm:px-8 sm:pt-8">
      <h2 id="cookie-consent-title" class="text-xl sm:text-2xl font-heading text-heading">
        Gestiona tus preferencias de cookies
      </h2>
      <p id="cookie-consent-description" class="mt-2 text-sm text-gray-600 leading-relaxed">
        Utilizamos cookies para analizar el tráfico del sitio y mostrar publicidad personalizada a través de Google Analytics y Google Ads. Elige qué categorías quieres habilitar. Puedes modificar tu decisión en cualquier momento.
      </p>
    </div>
    <div class="px-6 pb-6 sm:px-8 sm:pb-8">
      <form data-cookie-form>
        <fieldset class="space-y-4">
          <legend class="sr-only">Categorías de cookies</legend>
          {% if analytics_enabled %}
          <div class="flex items-start gap-3 rounded-xl border border-gray-200 px-4 py-3">
            <input
              class="mt-1 h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary"
              type="checkbox"
              id="cookie-preference-analytics"
              name="analytics"
              data-cookie-toggle="analytics"
            >
            <label class="flex-1" for="cookie-preference-analytics">
              <span class="block font-semibold text-body">Cookies analíticas</span>
              <span class="mt-1 block text-sm text-gray-600">
                Nos ayudan a entender el uso de la web y mejorar nuestros servicios mediante Google Analytics.
              </span>
            </label>
          </div>
          {% endif %}
          {% if ads_enabled %}
          <div class="flex items-start gap-3 rounded-xl border border-gray-200 px-4 py-3">
            <input
              class="mt-1 h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary"
              type="checkbox"
              id="cookie-preference-ads"
              name="ads"
              data-cookie-toggle="ads"
            >
            <label class="flex-1" for="cookie-preference-ads">
              <span class="block font-semibold text-body">Cookies de publicidad</span>
              <span class="mt-1 block text-sm text-gray-600">
                Permiten mostrar campañas personalizadas y medir su rendimiento a través de Google Ads.
              </span>
            </label>
          </div>
          {% endif %}
        </fieldset>
        <div class="mt-6 flex flex-col sm:flex-row sm:justify-end gap-3">
          <button
            type="button"
            class="w-full sm:w-auto rounded-full border border-gray-200 px-5 py-2 text-sm font-semibold text-body transition hover:border-body hover:text-heading"
            data-cookie-reject
          >
            Rechazar todas
          </button>
          <button
            type="button"
            class="w-full sm:w-auto rounded-full border border-primary px-5 py-2 text-sm font-semibold text-primary transition hover:bg-primary hover:text-white"
            data-cookie-save
          >
            Guardar selección
          </button>
          <button
            type="button"
            class="w-full sm:w-auto rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white transition hover:bg-primary-dark"
            data-cookie-accept
          >
            Aceptar todas
          </button>
        </div>
      </form>
      <button
        type="button"
        class="mt-6 block w-full text-center text-xs text-gray-500 underline"
        data-cookie-close
      >
        Cerrar sin cambios
      </button>
    </div>
  </div>
</div>
{% endif %}
