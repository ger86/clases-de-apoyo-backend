{% extends 'base_email.html.twig' %}

{% block body %}
<p>¡Gracias por tu compra!</p>
<p>Siguiendo el enlace que te dejamos a continuación puedes descargar el libro que acabas de adquirir:</p>
<table role="presentation" border="0" cellpadding="0" cellspacing="0" class="btn btn-primary">
  <tbody>
    <tr>
      <td align="left">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0">
          <tbody>
            <tr>
              <td><a href="{{ url }}">Descargar {{ book.title }}</a></td>
            </tr>
          </tbody>
        </table>
      </td>
    </tr>
  </tbody>
</table>
<p>Esperamos que te sirva de ayuda!!</p>
<p>Recuerda que si tienes cualquier problema puedes contestar a este email.</p>
{% endblock body %}